@charset "utf-8";

* { margin: 0px; padding: 0px; outline: none; }

body { background: rgba(52, 58, 65, 0.5); backdrop-filter: blur(5px); width=
: 100%; height: 100%; }

#ad_iframe { display: block; left: auto; margin: 0px auto; position: relati=
ve; top: auto; }

.creative { transition: opacity 1s ease 0s; position: relative; }

#card { background-color: rgb(255, 255, 255); border-radius: 6px; padding: =
10px 6px; position: relative; box-shadow: rgba(60, 64, 67, 0.15) 0px 8px 12=
px, rgba(60, 64, 67, 0.3) 0px 4px 4px; }

.attribution { position: relative; padding: 0px; margin: 12px 4px 0px; floa=
t: right; }

#ad_position_box { display: flex; align-items: center; justify-content: cen=
ter; height: 100vh; width: 100vw; }

.close-button { width: auto; height: 24px; opacity: 1; display: flex; flex-=
direction: row; border: none; z-index: 10001; cursor: pointer; margin: 0px;=
 position: relative; right: 0px; left: auto; background: transparent; borde=
r-radius: 0px; filter: none; }

.close-button-outer { width: auto; position: absolute; top: -30px; right: 0=
px; left: auto; z-index: 10000; }

.continue-prompt-text { display: flex; padding: 4.5px 0px; color: rgb(255, =
255, 255); font-weight: 600; font-family: Roboto, sans-serif; font-size: 14=
px; user-select: none; white-space: nowrap; }
